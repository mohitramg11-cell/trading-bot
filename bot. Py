def send(msg):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
    requests.post(url, data={"chat_id": CHAT_ID, "text": msg})

def generate_signal(stock):
    df = yf.download(stock, period="5d", interval="5m")

    df['ema50'] = ta.trend.ema_indicator(df['Close'], window=50)
    df['ema200'] = ta.trend.ema_indicator(df['Close'], window=200)
    df['rsi'] = ta.momentum.rsi(df['Close'], window=14)
    df['vol_avg'] = df['Volume'].rolling(20).mean()

    df['recent_high'] = df['High'].rolling(20).max()
    df['recent_low'] = df['Low'].rolling(20).min()

    last = df.iloc[-1]

    if (
        last['ema50'] > last['ema200'] and
        55 < last['rsi'] < 65 and
        last['Volume'] > 2 * last['vol_avg'] and
        last['Close'] > last['recent_high']
    ):
        return "SUPER BUY", last['Close']

    elif (
        last['ema50'] < last['ema200'] and
        35 < last['rsi'] < 45 and
        last['Volume'] > 2 * last['vol_avg'] and
        last['Close'] < last['recent_low']
    ):
        return "SUPER SELL", last['Close']

    return None, None

