# 🧠 SCORE SYSTEM
def get_score(df):
    score = 0
    last = df.iloc[-1]

    if last['ema50'] > last['ema200']:
        score += 2

    if 55 < last['rsi'] < 65:
        score += 2

    if last['Volume'] > 1.5 * last['vol_avg']:
        score += 2

    if last['Close'] > last['recent_high']:
        score += 2

    return score

# 📈 ENTRY / SL / TARGET
def get_trade_levels(df, signal):
    last = df.iloc[-1]

    entry = last['Close']
    swing_high = df['High'].rolling(10).max().iloc[-1]
    swing_low = df['Low'].rolling(10).min().iloc[-1]

    if signal == "BUY":
        sl = swing_low
        risk = entry - sl
        target = entry + (risk * 1.5)
    else:
        sl = swing_high
        risk = sl - entry
        target = entry - (risk * 1.5)

    return entry, sl, target

